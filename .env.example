# GitHub OAuth App，生产回调地址：
# https://blog.yusen.best/api/console/callback
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
# 生产站点公开域名，不要填 Netlify Function 的内部地址。
GITHUB_OAUTH_PUBLIC_ORIGIN="https://blog.yusen.best"

# 至少 32 字符，只用于签发 HttpOnly 登录 Cookie。
GITHUB_SESSION_SECRET=""

# Fine-grained PAT，仅授权 Little-W/blog，Contents 设为 Read and write。
GITHUB_REPO_TOKEN=""
GITHUB_REPO_OWNER="Little-W"
GITHUB_REPO_NAME="blog"
GITHUB_REPO_BRANCH="main"

# 看板娘对话使用硅基流动 Chat Completions API。密钥只配置在 Netlify，不要写入前端。
SILICONFLOW_API_KEY=""
WAIFU_CHAT_MODEL="Qwen/Qwen3-8B"
WAIFU_CHAT_PUBLIC_ORIGIN="https://blog.yusen.best"
